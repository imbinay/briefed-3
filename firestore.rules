rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Full user document — private. Only the owner may read or write.
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;

      match /quiz_results/{resultId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Public leaderboard — any signed-in user may read, owner may write.
    // Contains only: displayName, photoUrl, knowledgeScore, streak.
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    match /quizzes/{quizDate} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasOnly(['date', 'updatedAt']);

      match /scores/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }
    }

    // Hot Take aggregate vote counts — any signed-in user may read or update.
    match /hot_takes/{questionId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }
  }
}
